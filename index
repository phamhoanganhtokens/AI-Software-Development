<script>
// --- 3D Background Canvas ---
const canvas = document.getElementById('bg-canvas');
const ctx = canvas.getContext('2d');
let particles = [];

function initCanvas() {
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;
particles = [];
for (let i = 0; i < 80; i++) {
particles.push({
x: Math.random() * canvas.width,
y: Math.random() * canvas.height,
vx: (Math.random() - 0.5) * 0.5,
vy: (Math.random() - 0.5) * 0.5,
size: Math.random() * 2
});
}
}

function animateCanvas() {
ctx.clearRect(0, 0, canvas.width, canvas.height);
ctx.fillStyle = 'rgba(255, 255, 255, 0.2)';
particles.forEach(p => {
p.x += p.vx;
p.y += p.vy;
if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
ctx.beginPath();
ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
ctx.fill();
});

// Drawing lines between close particles
for (let i = 0; i < particles.length; i++) {
for (let j = i + 1; j < particles.length; j++) {
const dx = particles[i].x - particles[j].x;
const dy = particles[i].y - particles[j].y;
const dist = Math.sqrt(dx * dx + dy * dy);
if (dist < 150) {
ctx.strokeStyle = `rgba(59, 130, 246, ${0.15 * (1 - dist / 150)})`;
ctx.lineWidth = 0.5;
ctx.beginPath();
ctx.moveTo(particles[i].x, particles[i].y);
ctx.lineTo(particles[j].x, particles[j].y);
ctx.stroke();
}
}
}
requestAnimationFrame(animateCanvas);
}

initCanvas();
animateCanvas();
window.addEventListener('resize', initCanvas);

// --- Scroll Reveal ---
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
entries.forEach(entry => {
if (entry.isIntersecting) {
entry.target.classList.add('active');
}
});
}, { threshold: 0.1 });

reveals.forEach(r => observer.observe(r));

// --- macOS 3D Rotating Carousel ---
const projects = [
{ id: 1, name: "AI Content Agent", desc: "Sáng tạo nội dung đa nền tảng tối ưu hóa SEO và nhận diện thương hiệu.", icon: "✍️" },
{ id: 2, name: "AI Code Agent", desc: "Đẩy nhanh tiến độ phát triển với khả năng lập trình và kiểm thử tự động.", icon: "💻" },
{ id: 3, name: "AI Design Agent", desc: "Kiến tạo giao diện và đồ họa chuyên nghiệp từ ngôn ngữ tự nhiên.", icon: "🎨" },
{ id: 4, name: "AI SEO Agent", desc: "Phân tích thị trường và tối ưu hóa thứ hạng tìm kiếm hoàn toàn tự động.", icon: "🔍" },
{ id: 5, name: "Opal Workflow Agent", desc: "Trung tâm điều phối toàn bộ quy trình vận hành hệ sinh thái thông minh.", icon: "💎" }
];

const carousel = document.getElementById('carousel');
let currDegree = 0;
const count = projects.length;
const angle = 360 / count;
const radius = 400; // Distance from center

projects.forEach((proj, idx) => {
const item = document.createElement('div');
item.className = 'carousel-item';
const theta = angle * idx;

item.style.transform = `rotateY(${theta}deg) translateZ(${radius}px)`;
item.innerHTML = `
<div class="text-6xl mb-6">${proj.icon}</div>
<h3 class="text-2xl font-bold mb-4 text-center">${proj.name}</h3>
<p class="text-sm text-gray-400 text-center leading-relaxed text-justify">${proj.desc}</p>
<div class="mt-8 px-4 py-2 border border-white/10 rounded-lg text-xs tracking-widest uppercase">Xem Chi Tiết</div>
`;
carousel.appendChild(item);
});

function rotateCarousel(direction) {
if (direction === 'next') currDegree -= angle;
else currDegree += angle;
carousel.style.transform = `rotateY(${currDegree}deg)`;
}

document.getElementById('nextBtn').addEventListener('click', () => rotateCarousel('next'));
document.getElementById('prevBtn').addEventListener('click', () => rotateCarousel('prev'));

// Mouse hover 3D effect on cards
document.addEventListener('mousemove', (e) => {
const centerX = window.innerWidth / 2;
const centerY = window.innerHeight / 2;
const deltaX = (e.clientX - centerX) / 50;
const deltaY = (e.clientY - centerY) / 50;

// Subtle parralax for background or hero items
// Not overdoing it for stability
});

</script>
